<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_header"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="4dp"
        android:orientation="horizontal"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/header_title"
            android:textColor="@color/text_on_primary"
            android:textSize="19sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <Button
            android:id="@+id/btn_info"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:text="ⓘ"
            android:textColor="@color/text_on_primary"
            android:textSize="20sp"
            android:focusable="true" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── Status card ─── -->
            <LinearLayout
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/status_root"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/status_region"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/status_blob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:padding="4dp" />
            </LinearLayout>

            <!-- ─── Gating card (no blob) ─── -->
            <LinearLayout
                android:id="@+id/card_gate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gate_title"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/gate_explain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:id="@+id/btn_download"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_download"
                    style="@style/BtnPrimary"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_pick"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_pick"
                    style="@style/BtnOutline"
                    android:layout_marginBottom="14dp" />

                <ProgressBar
                    android:id="@+id/dl_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/dl_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/manual_url_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:id="@+id/manual_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_summary"
                    android:padding="10dp"
                    android:textColor="@color/code_color"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp" />

                <Button
                    android:id="@+id/btn_copy_url"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_copy_url"
                    style="@style/BtnOutline"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ─── Action card (have blob) ─── -->
            <LinearLayout
                android:id="@+id/card_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_swap"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    style="@style/BtnPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btn_swap_nobackup"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    style="@style/BtnOutline"
                    android:textColor="@color/warn"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ─── Error card ─── -->
            <LinearLayout
                android:id="@+id/card_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/error_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/warn"
                    android:textSize="13sp"
                    android:padding="4dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
